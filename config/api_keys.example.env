# ============================================================
#  social-auto-workflow – API Keys Example
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit the real .env file to version control.
# ============================================================

# ── OpenAI (image + text generation) ──────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Stable Diffusion (image generation) ───────────────────
STABILITY_API_KEY=your_stability_api_key_here

# ── Runway ML (short video generation) ────────────────────
RUNWAY_API_KEY=your_runway_api_key_here

# ── Pictory (long video generation) ───────────────────────
PICTORY_CLIENT_ID=your_pictory_client_id_here
PICTORY_CLIENT_SECRET=your_pictory_client_secret_here

# ── Facebook / Instagram (Meta Graph API) ─────────────────
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# ── TikTok Business API ────────────────────────────────────
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_OPEN_ID=your_tiktok_open_id_here

# ── YouTube Data API v3 ────────────────────────────────────
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# ── Pinterest API ──────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here
PINTEREST_BOARD_ID=your_pinterest_board_id_here

# ── CDN (required for Instagram & Pinterest image URLs) ────
# Upload generated images to a public CDN and set the URL here.
# Example: https://your-bucket.s3.amazonaws.com/daily_image.png
PUBLIC_IMAGE_URL=https://your-cdn.example.com/daily_image.png
